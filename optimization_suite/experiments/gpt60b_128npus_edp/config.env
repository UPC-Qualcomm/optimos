# Experiment identity
EXP_NAME="gpt60b_128npus_edp"
JOB_NAME="gpt60b_128npus_edp"

# Model/objective settings
MODEL_NAME="GPT_60B_56L"
MODEL_NUM=19
NUM_NPUS=128
OBJECTIVE_KEY="edp"

# Search space settings
INCLUDE_CATEGORIES="parallelism_strategy,network,system,model"
ENABLE_TRACKER=False

# Early stopping (optional — leave unset or empty to disable)
# Stop if no improvement after this many consecutive evaluations.
# Recommended: 3-5x N_WORKERS. Example for 8 workers: 40.
# EARLY_STOPPING_PATIENCE=40
# Minimum valid (non-failure) evals before patience counting starts.
# Recommended: at least INIT_SAMPLES so random phase is protected.
# EARLY_STOPPING_MIN_EVALUATIONS=100

# Optimization settings
BUDGET=400
INIT_SAMPLES=60
N_WORKERS=8
TOP_K=10
CLEANUP_BATCH_SIZE=20


# Resource policy (used by launch_all.sh)
CORES_PERCENT=32 
# Optional hard overrides:
# CPUS_PER_TASK_OVERRIDE=
# MEM_PER_CPU_GB_OVERRIDE=
# PARTITION_OVERRIDE=

# Paths
SWEEP_SCRIPT="../../../Optimization/examples/example_deephyper_opt_sweep.py"
START_ENV_SCRIPT="../../start_py_311.sh"
SEARCH_SPACE_PATH="inputs/search_space.json"
RESULT_FOLDER_PREFIX="outputs"
