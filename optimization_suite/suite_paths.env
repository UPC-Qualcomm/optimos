# =============================================================================
# suite_paths.env — Machine-specific path configuration
# =============================================================================
# Edit these two variables to port the entire suite to another machine.
# Every script in this suite sources this file; no other file contains a
# hardcoded machine path.
#
# SCRATCH_BASE  — root of the scratch/work area where the astra-sim tree lives
#                 and where experiment outputs/logs are written.
#   SLURM cluster : /scratch/nas/4/nasser
#   Ubuntu local  : /home/myuser/work   (or any writable directory)
#
# STG_TMP_BASE  — base directory for per-job staging temp dirs (STG_TMP_DIR).
#   SLURM cluster : $SCRATCH_BASE/tmp   (on shared NFS, set explicitly below)
#   Ubuntu local  : /tmp               (fast local disk, no NFS races)
# =============================================================================

SCRATCH_BASE="/media/mohammad/extension/sc26"
STG_TMP_BASE="${SCRATCH_BASE}/tmp"   # change to /tmp for a local Ubuntu machine
